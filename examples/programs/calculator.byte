fn main() -> int {
    num1 = input("Enter 1st number: ").parse_int()
    num2 = input("Enter 2nd number: ").parse_int()
    op = input("Enter operator: ")
    if op == "+" {
        print((num1 + num2).to_string())
    } else if op == "-" {
        print((num1 - num2).to_string())
    } else if op == "*" || op == "x" {
        print((num1 * num2).to_string())
    } else if op == "/" {
        print((num1 / num2).to_string())
    }
    
    return 0
}

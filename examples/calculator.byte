fn main() -> int {
    num1 = input().parse_int()
    num2 = input().parse_int()
    op = input()
    if op == "+" {
        print((num1 + num2).to_string())
    } else if op == "-" {
        print((num1 - num2).to_string())
    } else if op == "*" || op == "x" {
        print((num1 * num2).to_string())
    } else if op == "/" {
        print((num1 / num2).to_string())
    }
    
    return 0
}

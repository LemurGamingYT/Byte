fn is_even(int n) -> bool {
    return n % 2 == 0
}

fn collatz_conjecture(mut int n) -> int {
    mut steps = 0
    while n != 1 {
        if is_even(n) {
            n /= 2
        } else {
            n = 3 * n + 1
        }
        
        steps += 1
    }
    
    return steps
}

fn main() -> int {
    num = 10
    steps = collatz_conjecture(num)
    print(num.to_string() + " takes " + steps.to_string() + " steps to reach 1")
    return 0
}
